{
  "name": "Secure AI Agent Sandbox",

  // Reference to docker-compose.yml, which mounts the host docker.sock
  "dockerComposeFile": "docker-compose.yml",

  // Name of the service from docker-compose to use as the dev environment
  "service": "devcontainer",

  // Default folder the editor opens to after startup
  "workspaceFolder": "/workspace",

  // Ensures the editor runs as a non-root user defined in the Dockerfile
  "remoteUser": "node",

  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Settings specific to the editor and AI tools
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      },
      // Core extensions that are automatically installed in the container
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "prisma.prisma",
        "dsznajder.es7-react-js-snippets",
        "usernamehw.errorlens",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },

  "forwardPorts": [3000, 3001, 3002, 5432, 6080],

  // Commands that run after the container is successfully built
  // pnpm store prune saves disk space and pnpm install prepares dependencies
  "postCreateCommand": "bash ./.devcontainer/postCreateCommand.sh"
}
