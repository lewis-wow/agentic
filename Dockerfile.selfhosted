# syntax=docker/dockerfile:1
FROM node:20-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

FROM base AS pruner
WORKDIR /app
RUN npm install -g turbo@^2
COPY . .
RUN turbo prune @repo/api-server @repo/sdk-bff @repo/dashboard --docker

FROM base AS installer
WORKDIR /app
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
# packages/prisma's postinstall runs `prisma generate`, which needs the schema
# file present — out/json only has package.jsons, so copy the schema in too.
COPY --from=pruner /app/out/full/packages/prisma/prisma ./packages/prisma/prisma
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

FROM installer AS builder
COPY --from=pruner /app/out/full/ .
# NEXT_PUBLIC_* vars are baked into the client bundle at build time — dotenvx at startup is too late
ARG NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
RUN SKIP_ENV_VALIDATION=true pnpm turbo build --filter=@repo/api-server --filter=@repo/sdk-bff --filter=@repo/dashboard
RUN pnpm --filter=@repo/api-server deploy --prod --legacy /standalone/api
RUN pnpm --filter=@repo/sdk-bff deploy --prod --legacy /standalone/bff

FROM node:20-alpine AS runner
WORKDIR /app
RUN apk add --no-cache tini bash
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nodejs
RUN npm install -g @dotenvx/dotenvx --quiet

COPY --from=builder --chown=nodejs:nodejs /standalone/api ./api
# dist/ is gitignored so pnpm deploy may skip it — copy explicitly
COPY --from=builder --chown=nodejs:nodejs /app/apps/api/dist ./api/dist

COPY --from=builder --chown=nodejs:nodejs /standalone/bff ./bff
COPY --from=builder --chown=nodejs:nodejs /app/apps/bff/dist ./bff/dist

# In a monorepo, Next's standalone output nests the server entrypoint at
# apps/dashboard/server.js (mirroring the workspace layout) instead of at the
# standalone root — copy the whole tree as-is rather than flattening it.
COPY --from=builder --chown=nodejs:nodejs /app/apps/dashboard/.next/standalone ./dashboard
COPY --from=builder --chown=nodejs:nodejs /app/apps/dashboard/.next/static ./dashboard/apps/dashboard/.next/static
COPY --from=builder --chown=nodejs:nodejs /app/apps/dashboard/public ./dashboard/apps/dashboard/public
COPY --from=builder --chown=nodejs:nodejs /app/apps/dashboard/.env.production ./dashboard/apps/dashboard/.env.production

# ADR-0026: the combined image runs its own migration step, so it needs the
# prisma CLI + schema too. `packages/prisma` is already part of the pruned
# scope (all three apps depend on @repo/prisma), so the CLI (a devDependency,
# installed since `pnpm install` here has no --prod flag) already exists in
# the builder's node_modules — reuse it rather than a separate install.
COPY --from=pruner --chown=nodejs:nodejs /app/out/full/ ./migrate/
COPY --from=builder --chown=nodejs:nodejs /app/node_modules ./migrate/node_modules
COPY --from=builder --chown=nodejs:nodejs /app/packages/prisma/node_modules ./migrate/packages/prisma/node_modules
ENV PATH="/app/migrate/packages/prisma/node_modules/.bin:/app/migrate/node_modules/.bin:$PATH"

COPY --chown=nodejs:nodejs docker/selfhosted-entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

USER nodejs
EXPOSE 3000 3002
HEALTHCHECK --interval=5s --timeout=5s --retries=10 --start-period=15s \
  CMD node -e "fetch('http://localhost:3002/health').then(r => process.exit(r.ok ? 0 : 1)).catch(() => process.exit(1))"
ENTRYPOINT ["tini", "--"]
CMD ["./entrypoint.sh"]
