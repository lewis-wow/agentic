# Copy to examples/ghcr-selfhosted/.env before running this example.
# Every value here is optional — the stack runs with none of them set.

# Only needed if you've encrypted your own apps/*/.env.production files with
# dotenvx and rebuilt on top of the published image (see this folder's
# README). The checked-in .env.production files this image ships with are
# unencrypted, so these are blank by default.
DOTENV_PRIVATE_KEY_API=
DOTENV_PRIVATE_KEY_BFF=
DOTENV_PRIVATE_KEY_DASHBOARD=
