# Copy to examples/pomerium/.env before running this example.
#
# These values must match the hardcoded ones in pomerium/config.yaml and
# docker-compose.yml's mock-idp CLIENTS_CONFIGURATION_INLINE — config.yaml
# is not template-substituted by Pomerium, so if you change a value here,
# change it there too.

# Shared secret Pomerium sends on X-Trusted-Proxy-Secret; apps/bff and
# apps/dashboard must see the same value to trust the Identity Header.
TRUSTED_PROXY_SECRET=pomerium-example-trusted-proxy-secret

# Email that becomes the installation's OWNER the first time it's seen.
# Matches the test user registered in mock-idp (see docker-compose.yml).
TRUSTED_PROXY_OWNER_EMAIL=owner@example.com
