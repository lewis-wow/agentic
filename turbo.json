{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "DATABASE_URL",
    "TRUSTED_PROXY_SECRET",
    "TRUSTED_PROXY_IDENTITY_HEADER",
    "TRUSTED_PROXY_OWNER_EMAIL",
    "TRUSTED_PROXY_LOGOUT_URL",
    "BFF_URL",
    "NEXT_PUBLIC_APP_URL",
    "SKIP_ENV_VALIDATION"
  ],
  "globalDependencies": [".env.*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@repo/prisma#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/**", "prisma.config.ts"],
      "outputs": ["src/generated/**"]
    },
    "@repo/api-server#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "src/generated/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "format": {},
    "format:check": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#dev:proxy": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
